# Copy this file to .env and fill in your values
# ─── AI Message Generation ───
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Email Sending (Resend) ───
RESEND_API_KEY=re_your-resend-api-key-here
OUTREACH_FROM_EMAIL=outreach@yourdomain.com
OUTREACH_FROM_NAME=Your Name

# ─── Your Business Info (used for email personalization) ───
OUTREACH_YOUR_NAME=Your Name
OUTREACH_YOUR_BUSINESS=Your Business Name
OUTREACH_YOUR_SERVICE=Brief description of what you offer
OUTREACH_YOUR_WEBSITE=https://yourdomain.com

# ─── Outreach Safety Settings (defaults shown) ───
# OUTREACH_DAILY_CAP=20
# OUTREACH_MIN_DELAY=45
# OUTREACH_MAX_DELAY=90
# OUTREACH_MIN_SCORE=30
# OUTREACH_DRY_RUN=false
# OUTREACH_REQUIRE_APPROVAL=true
# OUTREACH_PAUSED=false

# ─── Paths (defaults shown) ───
# OUTREACH_DB_PATH=output/outreach.db
# OUTREACH_LEAD_FILE=output/lead_tracker.xlsx
